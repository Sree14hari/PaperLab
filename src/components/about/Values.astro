---
const values = [
  [
    {
      ref: '01',
      name: 'Accuracy & Standards',
      description:
        'Academic guidelines are strict for a reason. We ensure complete, error-free compliance with university layout mandates, font specs, citation types, and page formatting margins.',
    },
    {
      ref: '02',
      name: 'Radical Simplicity',
      description:
        'Writing should be easy. We hide the complexity of compilation, package installations, and layout settings, providing a clean editor that lets you concentrate on research content.',
    },
  ],
  [
    {
      ref: '03',
      name: 'Seamless Collaboration',
      description:
        'Research is a team sport. PaperLab makes it easy to write alongside co-authors, share drafts with guides, and coordinate review comments directly inside the document workspace.',
    },
    {
      ref: '04',
      name: 'Academic Accessibility',
      description:
        'High-quality formatting tools should be accessible to everyone. We ensure students and researchers have access to templates and compilers without requiring costly licenses or heavy system rigs.',
    },
  ],
];
---

<section class="py-16 sm:py-20">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="flex flex-col gap-8 lg:gap-12">
      <h2 class="text-3xl font-medium tracking-tight sm:text-4xl">Our Values</h2>
      <div class="grid gap-8 lg:grid-cols-2">
        {
          values.map((column, index) => (
            <div class:list={['space-y-8', index === 1 && 'lg:mt-16']}>
              {column.map((value) => (
                <div class="bg-primary-500/10 dark:bg-primary-400/10 flex flex-col gap-12 rounded-3xl px-6 py-8">
                  <p class="text-sm">{value.ref}</p>
                  <div class="flex flex-col gap-4">
                    <h3 class="text-xl font-medium">{value.name}</h3>
                    <p class="text-primary-950/70 dark:text-primary-200/70 text-base sm:text-lg">
                      {value.description}
                    </p>
                  </div>
                </div>
              ))}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
