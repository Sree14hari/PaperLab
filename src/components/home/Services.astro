---
const services = [
  {
    step: '01',
    name: 'KTU Format Compliance',
    description:
      'Automatically matches the official APJ Abdul Kalam Technological University formatting guidelines. Fonts, line spacing, margins, and page numbering align perfectly with KTU requirements.',
  },
  {
    step: '02',
    name: 'IEEE Paper Builder',
    description:
      'Create standard double-column IEEE conference publications effortlessly. Write in a visual editor while we handle LaTeX compilations and math formatting in the background.',
  },
  {
    step: '03',
    name: 'Zero-Config Citations',
    description:
      'Manage reference lists seamlessly. Search by DOI, title, or upload a BibTeX file. PaperLab formats citations and bibliographies automatically in IEEE, APA, or MLA styles.',
  },
];
---

<section class="py-16 sm:py-20">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="flex flex-col gap-12 sm:gap-16">
      <h2 class="text-3xl font-medium tracking-tight sm:text-4xl">Core Features</h2>
      <div class="grid gap-8 lg:grid-cols-3">
        {
          services.map((service) => (
            <div class="bg-primary-500/10 dark:bg-primary-400/10 flex flex-col gap-12 rounded-3xl px-6 py-8">
              <p class="text-sm">{service.step}</p>
              <div class="flex flex-col gap-4">
                <h3 class="text-xl font-medium">{service.name}</h3>
                <p class="text-primary-950/70 dark:text-primary-200/70 text-base sm:text-lg">
                  {service.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
